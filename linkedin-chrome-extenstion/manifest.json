{
    "manifest_version": 2,
    "name": "Message Suggestion for LinkedIn",
    "version": "1.0",
    "description": "Provides quick message suggestions on LinkedIn.",
    "permissions": ["activeTab", "https://www.linkedin.com/*"],
    "content_scripts": [
        {
          "matches": ["https://www.linkedin.com/messaging/*"],
          "js": ["contentScript.js"]
        }
      ],
    "browser_action": {
      "default_popup": "popup.html",
      "default_icon": {
        "16": "images/icon16.png",
        "48": "images/icon48.png",
        "128": "images/icon128.png"
      }
    },
    "icons": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  }
  