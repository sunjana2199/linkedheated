{
  "manifest_version": 3,
  "name": "LinkedIn Post Scraper",
  "version": "1.0",
  "description": "Scrapes your LinkedIn posts: impressions, likes, comments, date, and link for the past 365 days.",
  "permissions": ["activeTab", "scripting", "storage", "downloads", "tabs"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LinkedIn Post Scraper"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*/recent-activity/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
